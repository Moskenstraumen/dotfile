alias ss="ssh 54.27"
alias sd="ssh 54.48"
alias so="ssh oracle"

alias vi=nvim
alias vim=nvim
alias vz="nvim ~/.zshrc"
alias vr="nvim ./README.md"
alias vt='vi "$(mktemp /tmp/vt.XXXXXX)"'

alias src="source ~/.zshrc"

alias vk='nvim ~/.config/kitty/kitty.conf'
