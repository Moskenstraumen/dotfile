alias proxy_off='unset http_proxy=http://127.0.0.1:7890 ; HTTP_PROXY=http://127.0.0.1:7890 ; https_proxy=http://127.0.0.1:7890 ; HTTPS_PROXY=http://127.0.0.1:7890'
